---
// One-page portfolio. Static, no client-side JS.
import "@fontsource-variable/source-serif-4";
import "@fontsource-variable/inter";

const title = "Yuliia — AI tools & GTM engineering";
const description =
  "A Ukrainian immigrant who taught herself to build AI tools that help people get through hard systems — starting with her own community.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <nav aria-label="Sections">
      <a href="#builds">Builds</a>
      <a href="#experience">Experience</a>
      <a href="#research">Research</a>
      <a href="/resume.pdf">Resume</a>
      <a href="#contact">Contact</a>
    </nav>
    <main>
      <header class="hero">
        <h1>Yuliia</h1>
        <p class="tagline">
          A Ukrainian immigrant who taught herself to build AI tools that help
          people get through hard systems — starting with her own community.
        </p>
        <p class="subline">
          Open to AI-enabled GTM engineering, RevOps, and applied-AI roles.
        </p>
        <p class="hero-actions">
          <a class="button" href="/resume.pdf">Resume (PDF)</a>
          <a class="button ghost" href="https://www.linkedin.com/in/erdyv-yuliia">LinkedIn</a>
          <a class="button ghost" href="https://github.com/AiYulia">GitHub</a>
        </p>
      </header>

      <section id="builds" aria-labelledby="builds-heading">
        <h2 id="builds-heading">Featured builds</h2>

        <article class="build">
          <h3>mrapply</h3>
          <p>
            A human-in-the-loop job-application machine. It watches ~55 company
            job boards, scores every posting against a candidate profile, and
            uses Claude to tailor a one-page resume and cover letter — then a
            human reviews and approves every application before anything is
            sent. 6,800+ postings discovered, 89 tailored application packets,
            73 passing tests. Built with Python, SQL, Claude API.
          </p>
        </article>

        <article class="build">
          <h3>lead-scoring-ml</h3>
          <p>
            A small, honest machine-learning study: on realistic funnel data,
            transparent logistic regression beats gradient boosting (ROC-AUC
            0.770 vs 0.741) — and can explain every score it gives. Documented
            synthetic dataset, reproducible end to end. scikit-learn, pandas.
          </p>
          <a class="project-link" href="https://github.com/AiYulia/lead-scoring-ml">View project</a>
        </article>

        <article class="build">
          <h3>speech-coach</h3>
          <p>
            An AI speech-coaching tool for English learners: structured
            practice sessions, instant feedback, progress tracking. Built to
            make daily deliberate practice actually happen. Python + Claude.
          </p>
        </article>

        <p class="meta-build">
          This site is a build too — Astro, fully static, no trackers, no keys.&nbsp;
          <a href="https://github.com/AiYulia/aiyulia.github.io">Source on GitHub</a>
        </p>
      </section>

      <section id="experience" aria-labelledby="experience-heading">
        <h2 id="experience-heading">Experience</h2>

        <article class="role">
          <div class="role-head">
            <h3>J.P. Morgan — Global Private Bank</h3>
            <span class="when">Summer 2024</span>
          </div>
          <p class="role-title">Summer Analyst, Global Families Group</p>
          <p>
            Worked a $7B portfolio across 35 ultra-high-net-worth clients:
            optimized asset-allocation models, built an automated data-flow
            system aggregating a client's $1B+ multi-bank portfolio (replacing
            manual processing), and co-delivered an outreach project that
            lifted monthly client acquisition 20%.
          </p>
        </article>

        <article class="role">
          <div class="role-head">
            <h3>Student Managed Investment Fund</h3>
            <span class="when">2024 – 2025</span>
          </div>
          <p class="role-title">Senior Analyst</p>
          <p>
            Two investment proposals approved by the Advisory Board on the
            strength of Monte Carlo simulation and DCF modeling.
          </p>
        </article>

        <article class="role">
          <div class="role-head">
            <h3>Business Analytics Department (university research)</h3>
            <span class="when">2022 – 2023</span>
          </div>
          <p class="role-title">Research Assistant</p>
          <p>
            Early-access GPT-4 research on financial-market sentiment:
            formulated and tested hypotheses on integrating stock-news
            sentiment into technical analysis; co-authored a
            department-supported paper showing a 5% forecast-accuracy gain
            over traditional NLP models.
          </p>
        </article>

        <article class="role">
          <div class="role-head">
            <h3>County Cleaners Corporation</h3>
            <span class="when">2022</span>
          </div>
          <p class="role-title">Financial Analyst</p>
          <p>
            Interactive Tableau dashboard on real-time sales + SQL budget
            modeling that surfaced inefficiencies and cut costs 3%.
          </p>
        </article>
      </section>

      <section id="research" aria-labelledby="research-heading">
        <h2 id="research-heading">Research &amp; education</h2>
        <p>
          Co-authored NLP research (with an early-access GPT-4 grant) showing
          large language models outperform traditional sentiment tools on
          financial forecasting — a +5% accuracy gain, and the starting point
          of everything on this page.
        </p>
        <p>
          B.S. Business Analytics, minor in Finance — GPA 4.0 (major) / 3.95
          (cumulative), Honors College with Distinction, full-ride scholarship.
        </p>
        <p class="credentials">
          SIE (FINRA) · Bloomberg Market Concepts · Microsoft Excel Associate
        </p>
      </section>

      <p class="impact">
        Founded a Ukraine-relief store that raised $44,500 for 32 war-affected
        children — 11.3M views, featured on Voice of America.
      </p>

      <p class="skills">
        Python · SQL · Claude / LLM agents · Automation · RevOps · Tableau /
        Power BI · Ukrainian / Russian (native)
      </p>

      <footer class="contact" id="contact">
        <a href="https://www.linkedin.com/in/erdyv-yuliia">LinkedIn</a>
        <a href="https://github.com/AiYulia">GitHub</a>
        <a href="/resume.pdf">Resume</a>
      </footer>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f0eee6;
    --card: #faf9f5;
    --text: #1f1e1d;
    --muted: #6b6a61;
    --rule: #e3ded2;
    --accent: #c15f3c;
    color-scheme: light dark;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1a1915;
      --card: #211f1a;
      --text: #edeae3;
      --muted: #a39f93;
      --rule: #33312b;
      --accent: #e08d63;
    }
  }

  * {
    margin: 0;
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    scroll-behavior: smooth;
  }

  body {
    font-family: "Inter Variable", -apple-system, "Segoe UI", Helvetica, Arial,
      sans-serif;
    color: var(--text);
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  nav {
    max-width: 44rem;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 0;
    display: flex;
    gap: 1.5rem;
    font-size: 0.9rem;
    font-weight: 500;
  }

  nav a {
    color: var(--muted);
  }

  nav a:hover,
  nav a:focus-visible {
    color: var(--accent);
  }

  main {
    max-width: 44rem;
    margin: 0 auto;
    padding: 4.5rem 1.5rem 5rem;
    animation: fade-in 0.6s ease-out both;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    main {
      animation: none;
    }
    html {
      scroll-behavior: auto;
    }
  }

  .hero {
    margin-bottom: 4.5rem;
  }

  h1 {
    font-family: "Source Serif 4 Variable", Georgia, "Times New Roman", serif;
    font-size: 3rem;
    font-weight: 550;
    letter-spacing: -0.015em;
    margin-bottom: 1.25rem;
  }

  .tagline {
    font-family: "Source Serif 4 Variable", Georgia, serif;
    font-size: 1.3rem;
    font-weight: 420;
    line-height: 1.5;
    max-width: 40rem;
  }

  .subline {
    margin-top: 1rem;
    color: var(--muted);
    font-size: 1rem;
  }

  .hero-actions {
    margin-top: 1.75rem;
    display: flex;
    gap: 0.75rem;
  }

  .button {
    display: inline-block;
    background: var(--accent);
    color: var(--bg);
    font-weight: 550;
    font-size: 0.95rem;
    padding: 0.55rem 1.1rem;
    border-radius: 8px;
  }

  .button:hover,
  .button:focus-visible {
    text-decoration: none;
    filter: brightness(1.07);
  }

  .button.ghost {
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--rule);
  }

  section {
    margin-bottom: 4rem;
  }

  h2 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 1.75rem;
  }

  .build {
    background: var(--card);
    border: 1px solid var(--rule);
    border-radius: 12px;
    padding: 1.5rem 1.75rem;
    margin-bottom: 1.25rem;
  }

  h3 {
    font-family: "Source Serif 4 Variable", Georgia, serif;
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .build p {
    color: var(--muted);
    margin-bottom: 0.75rem;
    font-size: 0.97rem;
  }

  .meta-build {
    margin-top: 1.25rem;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .role {
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .role:last-of-type {
    border-bottom: none;
  }

  .role-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .role h3 {
    font-size: 1.12rem;
    margin-bottom: 0.15rem;
  }

  .when {
    color: var(--muted);
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .role-title {
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 0.4rem;
  }

  .role p:last-child {
    color: var(--muted);
    font-size: 0.95rem;
  }

  #research p {
    margin-bottom: 0.9rem;
    max-width: 40rem;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover,
  a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .project-link {
    font-weight: 500;
    font-size: 0.95rem;
  }

  .project-link::after {
    content: " \2192";
  }

  .impact {
    border-top: 1px solid var(--rule);
    margin-top: 0;
    padding-top: 1.75rem;
    font-family: "Source Serif 4 Variable", Georgia, serif;
    font-size: 1.05rem;
  }

  .skills {
    margin-top: 1.5rem;
    font-size: 0.92rem;
    color: var(--muted);
  }

  .credentials {
    font-size: 0.92rem;
    color: var(--muted);
  }

  .contact {
    border-top: 1px solid var(--rule);
    margin-top: 3.5rem;
    padding-top: 1.75rem;
    display: flex;
    gap: 2rem;
    font-size: 0.97rem;
    font-weight: 500;
  }

  @media (max-width: 480px) {
    main {
      padding-top: 3rem;
    }
    h1 {
      font-size: 2.3rem;
    }
    .tagline {
      font-size: 1.12rem;
    }
    .build {
      padding: 1.25rem 1.25rem;
    }
    nav {
      gap: 1rem;
      font-size: 0.85rem;
      flex-wrap: wrap;
    }
    .role-head {
      flex-direction: column;
      gap: 0;
    }
  }
</style>
