---
// One-page portfolio. Static, no client-side JS.
import "@fontsource-variable/source-serif-4";
import "@fontsource-variable/inter";

const title = "Yuliia — AI tools & GTM engineering";
const description =
  "A Ukrainian immigrant who taught herself to build AI tools that help people get through hard systems — starting with her own community.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <header class="hero">
        <h1>Yuliia</h1>
        <p class="tagline">
          A Ukrainian immigrant who taught herself to build AI tools that help
          people get through hard systems — starting with her own community.
        </p>
        <p class="subline">
          Open to AI-enabled GTM engineering, RevOps, and applied-AI roles.
        </p>
      </header>

      <section aria-labelledby="builds-heading">
        <h2 id="builds-heading">Featured builds</h2>

        <article class="build">
          <h3>mrapply</h3>
          <p>
            A human-in-the-loop job-application machine. It watches ~55 company
            job boards, scores every posting against a candidate profile, and
            uses Claude to tailor a one-page resume and cover letter — then a
            human reviews and approves every application before anything is
            sent. 6,800+ postings discovered, 89 tailored application packets,
            73 passing tests. Built with Python, SQL, Claude API.
          </p>
          <a class="project-link" href="https://github.com/AiYulia/mrapply-demo">View project</a>
        </article>

        <article class="build">
          <h3>lead-scoring-ml</h3>
          <p>
            A small, honest machine-learning study: on realistic funnel data,
            transparent logistic regression beats gradient boosting (ROC-AUC
            0.770 vs 0.741) — and can explain every score it gives. Documented
            synthetic dataset, reproducible end to end. scikit-learn, pandas.
          </p>
          <a class="project-link" href="https://github.com/AiYulia/lead-scoring-ml">View project</a>
        </article>

        <article class="build">
          <h3>speech-coach</h3>
          <p>
            An AI speech-coaching tool for English learners: structured
            practice sessions, instant feedback, progress tracking. Built to
            make daily deliberate practice actually happen. Python + Claude.
          </p>
          <a class="project-link" href="https://github.com/AiYulia/speech-coach">View project</a>
        </article>
      </section>

      <p class="impact">
        Founded a Ukraine-relief store that raised $44,500 for 32 war-affected
        children — 11.3M views, featured on Voice of America.
      </p>

      <p class="skills">
        Python · SQL · Claude / LLM agents · Automation · RevOps · Tableau /
        Power BI · Ukrainian / Russian (native)
      </p>

      <p class="credentials">
        B.S. Business Analytics (minor Finance) · SIE (FINRA) · Bloomberg
        Market Concepts · Microsoft Excel Associate
      </p>

      <footer class="contact">
        <a href="https://www.linkedin.com/in/erdyv-yuliia">LinkedIn</a>
        <a href="https://github.com/AiYulia">GitHub</a>
      </footer>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f0eee6;
    --card: #faf9f5;
    --text: #1f1e1d;
    --muted: #6b6a61;
    --rule: #e3ded2;
    --accent: #c15f3c;
    color-scheme: light dark;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1a1915;
      --card: #211f1a;
      --text: #edeae3;
      --muted: #a39f93;
      --rule: #33312b;
      --accent: #e08d63;
    }
  }

  * {
    margin: 0;
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
  }

  body {
    font-family: "Inter Variable", -apple-system, "Segoe UI", Helvetica, Arial,
      sans-serif;
    color: var(--text);
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  main {
    max-width: 44rem;
    margin: 0 auto;
    padding: 6rem 1.5rem 5rem;
    animation: fade-in 0.6s ease-out both;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    main {
      animation: none;
    }
  }

  .hero {
    margin-bottom: 4.5rem;
  }

  h1 {
    font-family: "Source Serif 4 Variable", Georgia, "Times New Roman", serif;
    font-size: 3rem;
    font-weight: 550;
    letter-spacing: -0.015em;
    margin-bottom: 1.25rem;
  }

  .tagline {
    font-family: "Source Serif 4 Variable", Georgia, serif;
    font-size: 1.3rem;
    font-weight: 420;
    line-height: 1.5;
    max-width: 40rem;
  }

  .subline {
    margin-top: 1rem;
    color: var(--muted);
    font-size: 1rem;
  }

  h2 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 1.75rem;
  }

  .build {
    background: var(--card);
    border: 1px solid var(--rule);
    border-radius: 12px;
    padding: 1.5rem 1.75rem;
    margin-bottom: 1.25rem;
  }

  h3 {
    font-family: "Source Serif 4 Variable", Georgia, serif;
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .build p {
    color: var(--muted);
    margin-bottom: 0.75rem;
    font-size: 0.97rem;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover,
  a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .project-link {
    font-weight: 500;
    font-size: 0.95rem;
  }

  .project-link::after {
    content: " \2192";
  }

  .impact {
    border-top: 1px solid var(--rule);
    margin-top: 3.5rem;
    padding-top: 1.75rem;
    font-family: "Source Serif 4 Variable", Georgia, serif;
    font-size: 1.05rem;
  }

  .skills {
    margin-top: 1.5rem;
    font-size: 0.92rem;
    color: var(--muted);
  }

  .credentials {
    margin-top: 0.6rem;
    font-size: 0.92rem;
    color: var(--muted);
  }

  .contact {
    border-top: 1px solid var(--rule);
    margin-top: 3.5rem;
    padding-top: 1.75rem;
    display: flex;
    gap: 2rem;
    font-size: 0.97rem;
    font-weight: 500;
  }

  @media (max-width: 480px) {
    main {
      padding-top: 3.5rem;
    }
    h1 {
      font-size: 2.3rem;
    }
    .tagline {
      font-size: 1.12rem;
    }
    .build {
      padding: 1.25rem 1.25rem;
    }
  }
</style>
