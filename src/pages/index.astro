---
// One-page portfolio. Static, no client-side JS.
const title = "Yuliia — AI tools & GTM engineering";
const description =
  "A Ukrainian immigrant who taught herself to build AI tools that help people get through hard systems — starting with her own community.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <header class="hero">
        <h1>Yuliia</h1>
        <p class="tagline">
          A Ukrainian immigrant who taught herself to build AI tools that help
          people get through hard systems — starting with her own community.
        </p>
        <p class="subline">
          Open to AI-enabled GTM engineering, RevOps, and applied-AI roles.
        </p>
      </header>

      <section aria-labelledby="builds-heading">
        <h2 id="builds-heading">Featured builds</h2>

        <article class="build">
          <h3>mrapply</h3>
          <p>
            A human-in-the-loop job-application machine. It watches ~55 company
            job boards, scores every posting against a candidate profile, and
            uses Claude to tailor a one-page resume and cover letter — then a
            human reviews and approves every application before anything is
            sent. 3,700+ jobs discovered, 77 tailored application packets, ~57
            passing tests. Built with Python, SQL, Claude API.
          </p>
          <a class="project-link" href="https://github.com/AiYulia/mrapply-demo">View project</a>
        </article>

        <article class="build">
          <h3>speech-coach</h3>
          <p>
            An AI speech-coaching tool for English learners: structured
            practice sessions, instant feedback, progress tracking. Built to
            make daily deliberate practice actually happen. Python + Claude.
          </p>
          <a class="project-link" href="https://github.com/AiYulia/speech-coach">View project</a>
        </article>
      </section>

      <p class="impact">
        Founded a Ukraine-relief store that raised $44,500 for 32 war-affected
        children — 11.3M views, featured on Voice of America.
      </p>

      <p class="skills">
        Python · SQL · Claude / LLM agents · Automation · RevOps · Tableau /
        Power BI · Ukrainian / Russian (native)
      </p>

      <footer class="contact">
        <a href="https://www.linkedin.com/in/erdyv-yuliia">LinkedIn</a>
        <a href="https://github.com/AiYulia">GitHub</a>
      </footer>
    </main>
  </body>
</html>

<style>
  :root {
    --accent: #2563eb;
    --text: #1c1c1e;
    --muted: #5c5c61;
    --rule: #e4e4e7;
    --bg: #ffffff;
    color-scheme: light dark;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --accent: #7ca6ff;
      --text: #e8e8ea;
      --muted: #a0a0a8;
      --rule: #2e2e33;
      --bg: #131316;
    }
  }

  * {
    margin: 0;
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
  }

  body {
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial,
      sans-serif;
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  main {
    max-width: 40rem;
    margin: 0 auto;
    padding: 5rem 1.5rem 4rem;
    animation: fade-in 0.6s ease-out both;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    main {
      animation: none;
    }
  }

  .hero {
    margin-bottom: 3.5rem;
  }

  h1 {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .tagline {
    font-size: 1.15rem;
    max-width: 36rem;
  }

  .subline {
    margin-top: 0.75rem;
    color: var(--muted);
  }

  h2 {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .build {
    margin-bottom: 2.25rem;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 650;
    margin-bottom: 0.4rem;
  }

  .build p {
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover,
  a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .project-link::after {
    content: " \2192";
  }

  .impact {
    border-top: 1px solid var(--rule);
    margin-top: 3rem;
    padding-top: 1.5rem;
    font-size: 0.95rem;
  }

  .skills {
    margin-top: 1.25rem;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .contact {
    border-top: 1px solid var(--rule);
    margin-top: 3rem;
    padding-top: 1.5rem;
    display: flex;
    gap: 1.75rem;
    font-size: 0.95rem;
  }

  @media (max-width: 480px) {
    main {
      padding-top: 3.5rem;
    }
    h1 {
      font-size: 1.85rem;
    }
    .tagline {
      font-size: 1.05rem;
    }
  }
</style>
